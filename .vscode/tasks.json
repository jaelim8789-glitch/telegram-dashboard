{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Dev: Start all (frontend + backend)",
      "type": "shell",
      "command": ".\\dev.ps1",
      "windows": { "command": ".\\dev.ps1" },
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "panel": "new", "group": "dev" }
    },
    {
      "label": "Dev: Frontend only",
      "type": "shell",
      "command": "pnpm dev",
      "group": "build",
      "presentation": { "panel": "new", "group": "dev" }
    },
    {
      "label": "Dev: Backend only",
      "type": "shell",
      "command": "cd backend && $env:RELOAD='true'; $env:ENVIRONMENT='development'; python -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
      "windows": { "command": "cd backend; $env:RELOAD='true'; $env:ENVIRONMENT='development'; python -m uvicorn main:app --reload --host 0.0.0.0 --port 8000" },
      "group": "build",
      "presentation": { "panel": "new", "group": "dev" }
    },
    {
      "label": "Build: Frontend production",
      "type": "shell",
      "command": "pnpm build",
      "group": "build",
      "presentation": { "panel": "new", "group": "build" }
    },
    {
      "label": "TypeCheck",
      "type": "shell",
      "command": "pnpm typecheck",
      "group": "build",
      "presentation": { "panel": "new", "group": "test" }
    },
    {
      "label": "Lint",
      "type": "shell",
      "command": "pnpm lint",
      "group": "build",
      "presentation": { "panel": "new", "group": "test" }
    }
  ]
}
