{
  "name": "telegram-dashboard",
  "version": "0.1.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "prepare": "husky || true",
    "cap:build": "cross-env CAPACITOR=1 CAP_EXPORT_DIR=dist next build && npx cap copy",
    "cap:sync": "cross-env CAPACITOR=1 next build && npx cap sync",
    "cap:android": "cross-env CAPACITOR=1 next build && npx cap copy && npx cap open android",
    "cap:ios": "cross-env CAPACITOR=1 next build && npx cap copy && npx cap open ios"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "next lint --file"
    ]
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/app": "^8.1.1",
    "@capacitor/browser": "^8.0.4",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.2",
    "@capacitor/push-notifications": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.2",
    "@capacitor/status-bar": "^8.0.3",
    "@telegram-apps/telegram-ui": "^2.1.13",
    "@tma.js/sdk-react": "^3.0.23",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.23.0",
    "next": "^15.5.20",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.9.2",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "^15.5.20",
    "lint-staged": "^17.1.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
