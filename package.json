{
  "name": "telegram-dashboard",
  "version": "0.1.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.8.1",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "dev:legacy": "next dev",
    "build": "next build && node scripts/stamp-sw-buildhash.js",
    "start": "next start",
    "lint": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "prepare": "husky || true",
    "cap:build": "cross-env CAPACITOR=1 CAP_EXPORT_DIR=dist next build && npx cap copy",
    "cap:sync": "cross-env CAPACITOR=1 next build && npx cap sync",
    "cap:android": "cross-env CAPACITOR=1 next build && npx cap copy && npx cap open android",
    "cap:ios": "cross-env CAPACITOR=1 next build && npx cap open ios",
    "seed": "cd telegram-dashboard-backend && python scripts/seed_local.py",
    "openapi": "cd telegram-dashboard-backend && python -c \"from app.main import app; import json; open('../openapi.json','w').write(json.dumps(app.openapi(), indent=2))\"",
    "typegen": "npx openapi-typescript openapi.json -o src/lib/api.types.ts",
    "changelog": "npx conventional-changelog-cli -p angular -i CHANGELOG.md -s",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "jscpd": "jscpd src/ --min-lines 10 --min-tokens 50 --pattern \"src/**/*.{ts,tsx}\" --output report/jscpd",
    "knip": "knip --exclude-dirs node_modules,.next --production",
    "ts-strict-report": "node scripts/ts-strict-report.js",
    "quality:full": "npm run typecheck && npm run lint && pnpm jscpd && pnpm knip",
    "verify": "npm run typecheck && pnpm lint && pnpm build",
    "check-i18n": "node scripts/check_i18n_keys.js",
    "dev:with-backend": "concurrently \"npm run dev\" \"cd ../telegram-dashboard-backend && python -m uvicorn main:app --reload --port 8000\"",
    "test:unit": "jest",
    "test:unit:watch": "jest --watch",
    "test:unit:coverage": "jest --coverage",
    "port:check": "node scripts/port_handler.js",
    "features:list": "node -e \"const ff=require('./src/lib/featureFlags'); console.log(JSON.stringify(ff.FeatureFlags.getAll(), null, 2));\"",
    "i18n:report": "node scripts/check_i18n_keys.js",
    "cap:build:ios": "node scripts/build-capacitor-apps.js ios",
    "cap:build:android": "node scripts/build-capacitor-apps.js android",
    "cap:build:all": "node scripts/build-capacitor-apps.js",
    "sw:update": "echo 'Service Worker updated'",
    "tsc:watch": "node scripts/tsc-watch-daemon.mjs",
    "precommit:jsxcheck": "node scripts/jsx-in-ts-check.mjs",
    "precommit:all": "node scripts/jsx-in-ts-check.mjs && npm run typecheck && pnpm lint",
    "verify:deploy": "node scripts/deploy-checklist.mjs",
    "post-merge": "node scripts/post-merge.mjs",
    "dashboard:worktree": "node scripts/worktree-dashboard.mjs",
    "mock:webhook": "node scripts/mock-telegram-webhook.mjs",
    "status": "python scripts/telemon-status.py",
    "rollback": "bash scripts/rollback_deploy.sh",
    "revert": "bash scripts/revert_to_last_good.sh",
    "smoke-test": "bash scripts/smoke_test_deploy.sh",
    "props:docs": "node scripts/generate-props-cheatsheet.js",
    "pushsafe": "bash scripts/git-push-safe.sh",
    "merge:master": "bash scripts/git-merge-to-master.sh",
    "analyze": "cross-env ANALYZE=true npm run build",
    "bundle-report": "npx webpack-bundle-analyzer .next/static/js/*.js"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yaml,yml,md}": [
      "prettier --write"
    ],
    "*.py": [
      "autopep8 --in-place"
    ]
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/app": "^8.1.1",
    "@capacitor/browser": "^8.0.4",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.2",
    "@capacitor/push-notifications": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.2",
    "@capacitor/status-bar": "^8.0.3",
    "@sentry/nextjs": "^9",
    "@telegram-apps/telegram-ui": "^2.1.13",
    "@tma.js/sdk-react": "^3.0.23",
    "@xyflow/react": "^12.11.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.42.2",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.23.0",
    "next": "^15.5.20",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.9.2",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3",
    "@emotion/jest": "^11.11.0",
    "@next/bundle-analyzer": "^15.5.20",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-essentials": "^8",
    "@storybook/addon-interactions": "^8",
    "@storybook/blocks": "^8",
    "@storybook/nextjs": "^8",
    "@storybook/react": "^8",
    "@storybook/test": "^8",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^20",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "concurrently": "^8.2.2",
    "conventional-changelog-cli": "^5",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "^15.5.20",
    "eslint-plugin-import": "^2.31.0",
    "glob": "^10.3.10",
    "jest": "^29.7.0",
    "jscpd": "^5",
    "jwt-decode": "^4.0.0",
    "knip": "^6",
    "openapi-typescript": "^7",
    "prettier": "^3",
    "storybook": "^8",
    "tailwindcss": "^4",
    "ts-jest": "^29.1.2",
    "typescript": "^5",
    "webpack-bundle-analyzer": "^4.10.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}