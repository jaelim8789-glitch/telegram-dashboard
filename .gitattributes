# Auto-detect text files and normalize to LF
* text=auto eol=lf

# Force LF for all text files
*.sh    text eol=lf
*.py    text eol=lf
*.js    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.xml   text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.sql   text eol=lf
*.csv   text eol=lf

# Binary files
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.zip    binary
*.tar.gz binary
*.exe    binary
*.dll    binary
*.so     binary
*.dylib  binary

# Lockfiles — binary to prevent merge conflicts
pnpm-lock.yaml -diff
yarn.lock      -diff
package-lock.json -diff
