# Environment Variables
# Copy this to .env.local and fill in your values

# Backend API URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Database (for local backend)
DATABASE_URL=postgresql+asyncpg://telegram_dashboard:telegram_dashboard@localhost:5432/telegram_dashboard

# Redis (for local backend)
REDIS_URL=redis://localhost:6379/0

# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-random-secret

# Encryption key (for sensitive data at rest)
ENCRYPTION_KEY=change-me-to-a-32-byte-key

# Sentry DSN (optional)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Telegram API credentials (for backend)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=