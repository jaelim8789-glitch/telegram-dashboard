#!/bin/bash
# pre-push: 핫스팟 파일 충돌 방지 + lockfile 확인

HOTSPOT_FILES=(
  "src/components/workspace/tabs/SendTab.tsx"
  "src/lib/api.ts"
  "src/components/layout/Workspace.tsx"
  "src/components/layout/DashboardShell.tsx"
  "src/app/miniapp/MiniAppChat.tsx"
  "next.config.ts"
)

# 1. git log HEAD..origin/master 확인
git fetch origin master
BEHIND=$(git rev-list --count HEAD..origin/master)
if [ "$BEHIND" -gt 0 ]; then
  echo "❌ [$BEHIND commits behind origin/master](https://github.com/jaelim8789-glitch/telegram-dashboard/compare/master...$(git rev-parse HEAD))"
  echo "   Run: git pull --rebase origin master"
  exit 1
fi

# 2. 핫스팟 파일 수정 확인
CHANGED=$(git diff --name-only HEAD)
for HOT in "${HOTSPOT_FILES[@]}"; do
  if echo "$CHANGED" | grep -q "$HOT"; then
    echo "⚠️  HOTSPOT: $HOT"
    echo "   Check AGENTS.md: Is another agent working on this?"
    echo "   If sure, push with --no-verify"
  fi
done

# 3. package.json 변경 시 lockfile 확인
if echo "$CHANGED" | grep -q "package.json"; then
  if ! echo "$CHANGED" | grep -q "pnpm-lock.yaml"; then
    echo "❌ package.json changed but pnpm-lock.yaml not in this commit."
    echo "   Run: pnpm install --no-frozen-lockfile && git add pnpm-lock.yaml"
    exit 1
  fi
fi
