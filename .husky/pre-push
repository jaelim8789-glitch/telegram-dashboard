#!/usr/bin/env bash
# .husky/pre-push
# Encoding check: block push if any source files are not UTF-8

echo "🔍 Running pre-push encoding check..."
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
if [ -f "$SCRIPT_DIR/scripts/check-encoding.sh" ]; then
  bash "$SCRIPT_DIR/scripts/check-encoding.sh" --fix
  if [ $? -ne 0 ]; then
    echo "❌ Push blocked: some files had encoding issues (auto-fixed). Stage and commit the changes."
    exit 1
  fi
fi
echo "✅ Encoding check passed."
exit 0
